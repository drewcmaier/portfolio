		"@vercel/analytics": "^2.0.1",
		"esbuild": "^0.28.0",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"resend": "^6.12.3",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.8",
